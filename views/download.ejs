<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File Share - Download</title>
    <script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/downloader.css?v=<%= Date.now() %>">
</head>
<body>
    <div id="pageLoader" class="page-loader">
        <div class="loader-content">
            <div class="nothing-logo-loader"></div>
            <div class="loader-status">Connecting to signaling...</div>
        </div>
    </div>

    <div class="container" style="position: relative;">
        <button id="themeToggleBtn" class="theme-toggle" title="Toggle Theme">
            <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="5"></circle>
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
            </svg>
        </button>
        <h1>File Share</h1>
        
        <div id="status">Connecting to uploader...</div>
        
        <div id="streamAnimation" class="stream-animation" style="display: none;">
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
        </div>
        
        <div id="fileInfo">
            <p><strong>File:</strong> <span id="fileName"></span></p>
            <p><strong>Size:</strong> <span id="fileSize"></span></p>
            <button id="downloadBtn" class="btn btn-primary">Download File</button>
            <div id="downloadControls" style="display: none; gap: 0.5rem; width: 100%; margin-top: 1rem;">
                <button id="pausePlayBtn" class="btn btn-pause" style="flex: 1; margin: 0;">Pause Download</button>
                <button id="cancelBtn" class="btn btn-danger" style="flex: 1; margin: 0;">Cancel</button>
            </div>
        </div>
        
        <progress id="progressBar" value="0" max="100"></progress>
    </div>

    <script>
        window.config = {
            slug: "<%= slug %>",
            uploaderPeerId: "<%= uploaderPeerId %>",
            stunServer: "<%= stunServer %>",
            turnServer: "<%= turnServer %>",
            turnUser: "<%= turnUser %>",
            turnPass: "<%= turnPass %>"
        };
    </script>
    <script src="/js/downloader.js?v=<%= Date.now() %>"></script>
</body>
</html>
