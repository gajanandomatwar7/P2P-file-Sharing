<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File Share - Send</title>
    <script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/uploader.css?v=<%= Date.now() %>">
</head>
<body>
    <div id="pageLoader" class="page-loader">
        <div class="loader-content">
            <div class="nothing-logo-loader"></div>
            <div class="loader-status">Initializing System</div>
        </div>
    </div>

    <div class="container" style="position: relative;">
        <button id="themeToggleBtn" class="theme-toggle" title="Toggle Theme">
            <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="5"></circle>
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
            </svg>
        </button>
        <h1>File Share</h1>
        
        <div id="restoreBanner" class="restore-banner">
            <p id="restoreMsg"></p>
            <div class="restore-actions">
                <button id="discardBtn" class="btn btn-danger btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.8rem;">Discard</button>
            </div>
        </div>

        <p id="instructionText">Select a file to start sharing. Senders must keep this tab open to allow peers to fetch files.</p>
        
        <div class="file-input-wrapper" id="uploadWrapper">
            <input type="file" id="fileInput">
            <div class="file-input-label">
                <span>📁 <strong>Choose a file</strong> or drag & drop</span>
                <span style="font-size: 0.8rem;">Direct browser-to-browser streaming</span>
            </div>
        </div>

        <div id="status">Initializing WebRTC...</div>
        
        <div id="streamAnimation" class="stream-animation" style="display: none;">
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
            <span class="anim-dot"></span>
        </div>
        
        <div id="linkContainer" style="display: none; align-items: center; justify-content: center; gap: 0.5rem; margin-top: 1.5rem; background: rgba(255, 255, 255, 0.05); padding: 1rem; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.08);">
            <div id="link" style="display: block; margin: 0; padding: 0; border: none; background: transparent;"></div>
            <button id="copyBtn" class="btn btn-secondary" style="padding: 0.5rem; width: auto; margin: 0; display: inline-flex; align-items: center; justify-content: center;" title="Copy to clipboard">
                <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                </svg>
            </button>
        </div>

        <div id="controlPanel">
            <div style="display: flex; gap: 0.5rem; justify-content: center; width: 100%;">
                <button id="pausePlayBtn" class="btn btn-pause" style="flex: 1;">Pause Upload</button>
                <button id="cancelTransferBtn" class="btn btn-danger" style="flex: 1;">Cancel Transfer</button>
            </div>
            <button id="resetBtn" class="btn btn-danger" style="margin-top: 1rem; width: 100%;">Reset Session</button>
        </div>
    </div>

    <script>
        window.config = {
            stunServer: "<%= stunServer %>",
            turnServer: "<%= turnServer %>",
            turnUser: "<%= turnUser %>",
            turnPass: "<%= turnPass %>"
        };
    </script>
    <script src="/js/uploader.js?v=<%= Date.now() %>"></script>
</body>
</html>
